<% layout("/layouts/boilerplate") %>
<div class="row">
    <div class="col-8 offset-2">
    <br>
    <h3>Create a new listing</h3>
    <form method="post" action="/listings">
        <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input name="listing[title]" 
        placeholder="enter title" 
        type="text" 
        class="form-control" /><!-- Here we have created key value pair. yaha par hamne ek object bana diya listing naam se aur uski key rakh di title-->
        </div>

        <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea name="listing[description]" 
        class="form-control"></textarea>
        </div>

        <div class="mb-3">
        <label for="image" class="form-label">Image Link</label>
         <input name="listing[image]" 
         placeholder="enter image url/link" 
         type="text" 
         class="form-control" />
         </div>
        
    <div class="row">
        <div class="mb-3 col-md-4">
        <label for="price" class="form-label">Price</label>
        <input name="listing[price]" 
        placeholder="enter price" 
        type="number" 
        class="form-control"/>
        </div>

        <div class="mb-3 col-md-8">
        <label for="country" class="form-label">country</label>   
        <input name="listing[country]" 
        placeholder="enter country" 
        type="text"
        class="form-control" />
        </div>
    </div>
        
        <div class="mb-3">
        <label for="location" class="form-label">Location</label>    
        <input name="listing[location]" 
        placeholder="enter location" 
        type="text" 
        class="form-control"/>
        </div>

        <button class="btn btn-dark add-btn">Add</button>
        <br>
    </form>
    </div>
</div>
